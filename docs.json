{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Lasso",
  "colors": {
    "primary": "#1B1F1F",
    "light": "#1B1F1F",
    "dark": "#1B1F1F"
  },
  "background": {
    "color": {
      "light": "#F1F3F3",
      "dark": "#1B1F1F"
    }
  },
  "favicon": "/favicon.png",
  "fonts": {
    "heading": {
      "family": "Mona Sans",
      "weight": 600,
      "source": "https://cdn.jsdelivr.net/fontsource/fonts/mona-sans:vf@latest/latin-wght-normal.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "api": {
    "baseUrl": "https://api.lasso.ai/v1",
    "auth": {
      "method": "bearer"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "quickstart/introduction"
            ]
          },
          {
            "group": "TypeScript",
            "icon": "js",
            "pages": [
              "quickstart/typescript/setup",
              "quickstart/typescript/extract",
              "quickstart/typescript/enhance",
              "quickstart/typescript/export"
            ]
          },
          {
            "group": "Python",
            "icon": "python",
            "pages": [
              "quickstart/python/setup",
              "quickstart/python/extract",
              "quickstart/python/enhance",
              "quickstart/python/export"
            ]
          },
          {
            "group": "Learn",
            "pages": [
              "learn/tables",
              "learn/schemas",
              "learn/enhancement",
              "learn/files",
              "learn/exports",
              "learn/glossary",
              "learn/credits"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "rectangle-terminal",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/errors",
              "api-reference/pagination",
              "api-reference/webhooks"
            ]
          },
          {
            "group": "Tables",
            "pages": [
              "api-reference/tables/list",
              "api-reference/tables/create",
              "api-reference/tables/get",
              "api-reference/tables/update",
              "api-reference/tables/delete",
              "api-reference/tables/columns",
              "api-reference/tables/export"
            ]
          },
          {
            "group": "Rows",
            "pages": [
              "api-reference/rows/list",
              "api-reference/rows/get",
              "api-reference/rows/update",
              "api-reference/rows/delete",
              "api-reference/rows/bulk-update",
              "api-reference/rows/bulk-delete",
              "api-reference/rows/traces"
            ]
          },
          {
            "group": "Enhance",
            "pages": [
              "api-reference/enhance/run",
              "api-reference/enhance/bulk",
              "api-reference/enhance/status",
              "api-reference/enhance/cancel"
            ]
          },
          {
            "group": "Schemas",
            "pages": [
              "api-reference/schemas/list",
              "api-reference/schemas/create",
              "api-reference/schemas/get",
              "api-reference/schemas/update",
              "api-reference/schemas/delete",
              "api-reference/schemas/generate"
            ]
          },
          {
            "group": "Files",
            "pages": [
              "api-reference/files/list",
              "api-reference/files/upload",
              "api-reference/files/delete"
            ]
          },
          {
            "group": "Glossary",
            "pages": [
              "api-reference/glossary/list",
              "api-reference/glossary/create",
              "api-reference/glossary/update",
              "api-reference/glossary/delete"
            ]
          },
          {
            "group": "Credits",
            "pages": [
              "api-reference/credits/balance",
              "api-reference/credits/usage"
            ]
          }
        ]
      }
    ],
    "global": {
    }
  },
  "logo": {
    "light": "/logo/dark.png",
    "dark": "/logo/light.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Sign In",
        "href": "https://app.lasso.ai/login"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.lasso.ai/register"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/lasso_ai",
      "github": "https://github.com/lasso-ai",
      "linkedin": "https://linkedin.com/company/lasso-ai"
    }
  }
}
